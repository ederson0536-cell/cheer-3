#!/usr/bin/env python3
"""
EvoClaw CLI Skill
直接通过 exec 调用
"""

import sys
import subprocess
from pathlib import Path

from evoclaw.workspace_resolver import resolve_workspace

WORKSPACE = resolve_workspace(__file__)

def main():
    message = " ".join(sys.argv[1:]) if len(sys.argv) > 1 else ""
    
    if not message:
        print("Usage: evoclaw <message>")
        print("Example: evoclaw 今天天气怎么样")
        return
    
    # Add to path
    sys.path.insert(0, str(WORKSPACE))
    sys.path.insert(0, str(WORKSPACE / "evoclaw" / "runtime"))

    from evoclaw.runtime.integrated_handler import IntegratedHandler
    
    handler = IntegratedHandler()
    result = handler.handle(message)
    
    print(result.get("result", result.get("message", str(result))))

if __name__ == "__main__":
    main()
