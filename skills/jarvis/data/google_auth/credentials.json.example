{
  "_anleitung": [
    "1. Google Cloud Console: https://console.cloud.google.com/",
    "2. Neues Projekt anlegen (oder vorhandenes wählen)",
    "3. APIs aktivieren: Gmail API, Drive API, Google Calendar API",
    "4. OAuth-Zustimmungsbildschirm konfigurieren (Extern, Test-Modus)",
    "5. Anmeldedaten > OAuth 2.0-Client-IDs erstellen (Typ: Webanwendung)",
    "6. Autorisierte Redirect-URIs hinzufügen: https://YOUR_SERVER_IP:8000/api/google/callback",
    "7. JSON herunterladen und als 'credentials.json' (ohne .example) speichern",
    "8. Test-Nutzer hinzufügen (eigene Google-Adresse)"
  ],
  "web": {
    "client_id": "HIER_CLIENT_ID.apps.googleusercontent.com",
    "client_secret": "HIER_CLIENT_SECRET",
    "redirect_uris": ["https://YOUR_SERVER_IP:8000/api/google/callback"],
    "auth_uri": "https://accounts.google.com/o/oauth2/auth",
    "token_uri": "https://oauth2.googleapis.com/token"
  }
}
