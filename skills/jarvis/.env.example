# ═══════════════════════════════════════════════════════════════════════════════
# Jarvis AI Agent – Konfiguration
# Kopiere diese Datei nach .env und trage deine Werte ein.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── LLM API Keys (mindestens einen eintragen) ──────────────────────────────
# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# OpenRouter (Zugang zu 100+ Modellen): https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Anthropic Claude: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── Server-Konfiguration ───────────────────────────────────────────────────
# Öffentliche IP oder Domain für SSL-Zertifikat (wichtig für Remote-Zugriff)
SERVER_IP=127.0.0.1
SERVER_PORT=8000

# ─── VNC / Desktop ──────────────────────────────────────────────────────────
VNC_PORT=5900
WEBSOCKIFY_PORT=6080

# ─── Sicherheit ─────────────────────────────────────────────────────────────
# Web-Login Passwort (Standard: jarvis – BITTE ÄNDERN!)
JARVIS_PASSWORD=jarvis

# Geheimer Schlüssel für HMAC-Token-Signierung (sicheren Zufallswert generieren!)
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-secure-random-string-min-32-chars
