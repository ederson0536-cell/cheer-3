{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/runtime/contracts/decision_trace.schema.json",
  "title": "Decision Trace",
  "type": "object",
  "required": [
    "trace_version",
    "schema_version",
    "router_version",
    "policy_version",
    "object_id",
    "decision_type",
    "selected",
    "candidates",
    "score_breakdown",
    "final_score",
    "decision"
  ],
  "properties": {
    "trace_version": {"type": "string"},
    "schema_version": {"type": "string"},
    "router_version": {"type": "string"},
    "policy_version": {"type": "string"},
    "object_id": {"type": "string"},
    "decision_type": {"type": "string", "enum": ["task_routing", "subtask_routing", "proposal_publish"]},
    "selected": {"type": "string"},
    "candidates": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "score_breakdown": {
      "type": "object",
      "properties": {
        "rule_alignment": {"type": "number"},
        "success_rate": {"type": "number"},
        "rework_rate": {"type": "number"},
        "latency_penalty": {"type": "number"},
        "trust_level": {"type": "number"},
        "scenario_match": {"type": "number"}
      },
      "additionalProperties": true
    },
    "final_score": {"type": "number", "minimum": 0, "maximum": 1},
    "decision": {"type": "string", "enum": ["auto_execute", "cautious_review_or_canary", "reject_auto"]},
    "metadata": {"type": "object"}
  },
  "additionalProperties": false
}
