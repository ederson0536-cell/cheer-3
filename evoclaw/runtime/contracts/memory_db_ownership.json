{
  "version": "2026-03-12",
  "policy": {
    "single_write_source": "memory.db",
    "json_projection_only": true,
    "notes": [
      "memory/*.json and memory/*.jsonl are no longer canonical state stores.",
      "JSON/JSONL outputs are allowed only as projection, debug report, or archive snapshots."
    ]
  },
  "tables": {
    "memories": {
      "owner": "runtime.message_handler",
      "purpose": "canonical interaction and experience memory events",
      "field_sources": {
        "id": "stable id from ingress payload",
        "category": "ingress/message classification",
        "type": "event type from runtime handlers",
        "content": "user/agent payload content",
        "source": "transport source (telegram/api/cli/cron)",
        "created_at": "ingress timestamp",
        "updated_at": "write/update timestamp",
        "significance": "runtime scoring",
        "tags_json": "runtime tags",
        "metadata_json": "hook/runtime metadata",
        "raw_json": "raw ingress payload snapshot"
      }
    },
    "proposals": {
      "owner": "runtime.components.proposal_processor",
      "purpose": "governance proposals and lifecycle",
      "field_sources": {
        "id": "proposal id",
        "type": "proposal type",
        "content": "proposal body",
        "source": "proposal source pipeline",
        "created_at": "proposal creation time",
        "updated_at": "proposal update time",
        "status": "pending/approved/rejected/published",
        "priority": "governance priority",
        "approved_at": "approval timestamp",
        "tags_json": "proposal tags",
        "metadata_json": "proposal metadata"
      }
    },
    "reflections": {
      "owner": "runtime.components.passive_learning",
      "purpose": "structured reflection outputs",
      "field_sources": {
        "id": "reflection id",
        "timestamp": "reflection execution timestamp",
        "trigger": "reflection trigger source",
        "notable_count": "aggregated notable experience count",
        "analysis_json": "reflection analysis",
        "proposals_json": "proposal suggestions from reflection",
        "created_at": "record creation timestamp"
      }
    },
    "graph_entities": {
      "owner": "runtime.components.graph_memory",
      "purpose": "knowledge graph entities",
      "field_sources": {
        "id": "entity id",
        "entity_type": "entity classification",
        "properties_json": "entity properties",
        "created_at": "insert timestamp"
      }
    },
    "graph_relations": {
      "owner": "runtime.components.graph_memory",
      "purpose": "knowledge graph relations",
      "field_sources": {
        "id": "relation id",
        "source_id": "source entity id",
        "target_id": "target entity id",
        "relation_type": "relation type",
        "properties_json": "relation metadata",
        "created_at": "insert timestamp"
      }
    },
    "soul_history": {
      "owner": "runtime.components.governance",
      "purpose": "SOUL mutation audit trail",
      "field_sources": {
        "id": "change id",
        "change_type": "change category",
        "old_value": "pre-change value",
        "new_value": "post-change value",
        "created_at": "change timestamp",
        "approved": "governance approval flag"
      }
    },
    "rules": {
      "owner": "runtime.components.rule_engine",
      "purpose": "active runtime rules",
      "field_sources": {
        "id": "rule id",
        "content": "rule text",
        "source_proposal_id": "linked proposal id",
        "created_at": "rule publish timestamp",
        "enabled": "rule enabled state"
      }
    },
    "candidates": {
      "owner": "runtime.components.candidate_memory",
      "purpose": "candidate skills and promotion tracking",
      "field_sources": {
        "id": "candidate id",
        "skill_id": "skill identifier",
        "task_type": "task category",
        "status": "candidate/promoted/rejected",
        "source": "candidate source subsystem",
        "score": "computed candidate score",
        "created_at": "candidate created timestamp",
        "updated_at": "candidate updated timestamp",
        "metadata_json": "candidate metrics",
        "raw_json": "raw candidate payload"
      }
    },
    "system_state": {
      "owner": "runtime.state_manager",
      "purpose": "small structured runtime state kv",
      "field_sources": {
        "key": "state key",
        "value_json": "state payload",
        "updated_at": "state update timestamp"
      }
    },
    "system_logs": {
      "owner": "runtime.logging",
      "purpose": "structured operational logs and write-failure records",
      "field_sources": {
        "id": "log id",
        "log_type": "log classification",
        "source": "subsystem source",
        "content": "message body",
        "created_at": "event timestamp",
        "updated_at": "update timestamp",
        "level": "info/warn/error",
        "metadata_json": "structured metadata",
        "raw_json": "raw payload"
      }
    },
    "task_runs": {
      "owner": "feedback_system.after_task",
      "purpose": "single message-task run summary written once per message",
      "field_sources": {
        "task_id": "message-level stable task id",
        "task_name": "message/task title",
        "task_type": "analyzed task type",
        "status": "task execution status",
        "success": "execution success flag",
        "satisfaction": "button feedback or default satisfied",
        "significance": "routine/notable classification",
        "skills_json": "skills used",
        "methods_json": "methods used",
        "execution_steps_json": "four-hook and execution traces",
        "thinking_json": "reasoning trace",
        "output_summary": "structured output summary",
        "final_message": "assistant final response",
        "source": "channel source",
        "created_at": "task creation timestamp",
        "updated_at": "last update timestamp",
        "metadata_json": "message_id/session_id/feedback metadata"
      }
    },
    "external_learning_events": {
      "owner": "runtime.components.active_learning",
      "purpose": "active learning records from external sources",
      "field_sources": {
        "id": "table primary id",
        "content": "normalized content payload",
        "source": "pipeline source",
        "created_at": "creation timestamp",
        "updated_at": "update timestamp",
        "metadata_json": "structured metadata"
      }
    },
    "notebook_experiences": {
      "owner": "runtime.components.passive_learning",
      "purpose": "notebook/task experience entries separated from generic memories",
      "field_sources": {
        "id": "table primary id",
        "content": "normalized content payload",
        "source": "pipeline source",
        "created_at": "creation timestamp",
        "updated_at": "update timestamp",
        "metadata_json": "structured metadata"
      }
    },
    "notebook_reflections": {
      "owner": "runtime.components.passive_learning",
      "purpose": "reflections extracted from notebook experiences",
      "field_sources": {
        "id": "table primary id",
        "content": "normalized content payload",
        "source": "pipeline source",
        "created_at": "creation timestamp",
        "updated_at": "update timestamp",
        "metadata_json": "structured metadata"
      }
    },
    "notebook_proposals": {
      "owner": "runtime.components.passive_learning",
      "purpose": "proposals extracted from notebook reflections",
      "field_sources": {
        "id": "table primary id",
        "content": "normalized content payload",
        "source": "pipeline source",
        "created_at": "creation timestamp",
        "updated_at": "update timestamp",
        "metadata_json": "structured metadata"
      }
    },
    "notebook_rules": {
      "owner": "runtime.components.passive_learning",
      "purpose": "rules published from notebook proposals",
      "field_sources": {
        "id": "table primary id",
        "content": "normalized content payload",
        "source": "pipeline source",
        "created_at": "creation timestamp",
        "updated_at": "update timestamp",
        "metadata_json": "structured metadata"
      }
    },
    "semantic_knowledge": {
      "owner": "runtime.components.active_learning",
      "purpose": "semantic layer linking graph entities/relations to text knowledge",
      "field_sources": {
        "id": "table primary id",
        "content": "normalized content payload",
        "source": "pipeline source",
        "created_at": "creation timestamp",
        "updated_at": "update timestamp",
        "metadata_json": "structured metadata"
      }
    }
  },
  "canonical_fields": {
    "id_fields": [
      "task_id",
      "event_id",
      "notebook_exp_id",
      "notebook_reflection_id",
      "notebook_proposal_id",
      "notebook_rule_id",
      "semantic_id"
    ],
    "time_fields": [
      "created_at",
      "updated_at",
      "collected_at"
    ],
    "status_fields": [
      "status",
      "significance",
      "satisfaction",
      "enabled"
    ],
    "payload_fields": [
      "content",
      "summary",
      "metadata_json",
      "analysis_json",
      "properties_json"
    ]
  },
  "relationships": {
    "task_runs.task_id": "notebook_experiences.task_id",
    "notebook_experiences.notebook_exp_id": "notebook_reflections.notebook_exp_id",
    "notebook_reflections.notebook_reflection_id": "notebook_proposals.notebook_reflection_id",
    "notebook_proposals.notebook_proposal_id": "notebook_rules.notebook_proposal_id",
    "graph_entities.id": "semantic_knowledge.entity_id",
    "graph_relations.id": "semantic_knowledge.relation_id"
  }
}
