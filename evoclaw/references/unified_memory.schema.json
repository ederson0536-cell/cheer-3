{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evoclaw.local/schemas/unified-memory.schema.json",
  "title": "EvoClaw Unified Memory Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "content",
    "source",
    "created_at",
    "updated_at",
    "tags",
    "metadata"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
